{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/listings.ts": {
      "maxDuration": 30
    },
    "api/internal/listings-debug.ts": {
      "maxDuration": 30
    },
    "api/internal/health.ts": {
      "maxDuration": 15
    },
    "api/image.ts": {
      "maxDuration": 30
    },
    "api/internal/sync-listings.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
